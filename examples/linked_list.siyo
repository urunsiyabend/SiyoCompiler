struct Node {
    value: int,
    next: int
}

fn main() {
    mut nodes = [
        Node { value: 10, next: 1 },
        Node { value: 20, next: 2 },
        Node { value: 30, next: -1 }
    ]

    // Traversal with string interpolation
    mut sum = 0
    mut current = 0
    while current != -1 {
        mut node = nodes[current]
        println("Node: ${node.value}")
        sum = sum + node.value
        current = node.next
    }
    println("Sum: $sum")
}
