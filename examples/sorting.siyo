{
    import "std/strings"

    mut numbers = [64, 34, 25, 12, 22, 11, 90]

    // Use built-in sort with comparator lambda
    sort(numbers, fn(a: int, b: int) -> int { a - b })

    // Format as string
    mut parts = [""]
    for mut i = 0 i < len(numbers) i = i + 1 {
        if i == 0 {
            parts[0] = toString(numbers[i])
        } else {
            push(parts, toString(numbers[i]))
        }
    }
    "[" + strings.join(parts, ", ") + "]"
}
