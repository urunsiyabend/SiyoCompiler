// Math test suite using std/testing
import "std/testing"

// Math functions to test
fn abs(x: int) -> int {
    if x < 0 return -x
    x
}

fn fibonacci(n: int) -> int {
    if n <= 1 return n
    fibonacci(n - 1) + fibonacci(n - 2)
}

fn isPrime(n: int) -> bool {
    if n < 2 return false
    for i in range(2, n) {
        if n % i == 0 return false
    }
    true
}

fn gcd(mut a: int, mut b: int) -> int {
    while b != 0 {
        mut temp = b
        b = a % b
        a = temp
    }
    a
}

fn power(base: int, exp: int) -> int {
    mut result = 1
    for i in range(0, exp) {
        result = result * base
    }
    result
}

fn main() {
    // Run tests
    println("=== Math Test Suite ===")
    println("")

    println("Absolute Value:")
    testing.assertEqual(toString(abs(5)), "5", "abs(5) = 5")
    testing.assertEqual(toString(abs(-5)), "5", "abs(-5) = 5")
    testing.assertEqual(toString(abs(0)), "0", "abs(0) = 0")

    println("")
    println("Fibonacci:")
    testing.assertEqual(toString(fibonacci(0)), "0", "fib(0) = 0")
    testing.assertEqual(toString(fibonacci(1)), "1", "fib(1) = 1")
    testing.assertEqual(toString(fibonacci(5)), "5", "fib(5) = 5")
    testing.assertEqual(toString(fibonacci(10)), "55", "fib(10) = 55")

    println("")
    println("Prime:")
    testing.assert(!isPrime(0), "0 is not prime")
    testing.assert(!isPrime(1), "1 is not prime")
    testing.assert(isPrime(2), "2 is prime")
    testing.assert(isPrime(7), "7 is prime")
    testing.assert(!isPrime(9), "9 is not prime")
    testing.assert(isPrime(97), "97 is prime")

    println("")
    println("GCD:")
    testing.assertEqual(toString(gcd(12, 8)), "4", "gcd(12,8) = 4")
    testing.assertEqual(toString(gcd(100, 75)), "25", "gcd(100,75) = 25")
    testing.assertEqual(toString(gcd(17, 13)), "1", "gcd(17,13) = 1")

    println("")
    println("Power:")
    testing.assertEqual(toString(power(2, 10)), "1024", "2^10 = 1024")
    testing.assertEqual(toString(power(3, 4)), "81", "3^4 = 81")
    testing.assertEqual(toString(power(5, 0)), "1", "5^0 = 1")

    println("")
    println("String:")
    testing.assert("hello" + " " + "world" == "hello world", "concatenation")
    testing.assert(substring("hello world", 0, 5) == "hello", "substring")
    testing.assert(contains("hello world", "world"), "contains")
    testing.assert(!contains("hello", "xyz"), "not contains")

    println("")
    println("=== All tests complete ===")
}
