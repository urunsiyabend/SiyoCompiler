{
    fn fizzbuzz(n: int) -> string {
        if n % 15 == 0 return "FizzBuzz"
        if n % 3 == 0 return "Fizz"
        if n % 5 == 0 return "Buzz"
        return toString(n)
    }

    mut result = ""
    for mut i = 1 i <= 20 i = i + 1 {
        mut line = fizzbuzz(i)
        if i > 1 {
            result = result + ", " + line
        } else {
            result = line
        }
    }
    result
}
