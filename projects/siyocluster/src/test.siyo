// siyocluster tests — verifies Store and NodeState actor logic without TCP
import "std/testing"
import "std/strings"
import java "java.lang.System"
import java "java.lang.Thread"

// ==================== Store Actor (copied for unit testing) ====================

actor Store {
    data: map
}

impl Store {
    fn new() -> Store {
        Store { data: map() }
    }

    fn get(self, key: string) -> string {
        if self.data.has(key) {
            return toString(self.data.get(key))
        }
        return "(nil)"
    }

    fn set(self, key: string, value: string) -> string {
        self.data.set(key, value)
        return "OK"
    }

    fn del(self, key: string) -> string {
        if self.data.has(key) {
            self.data.remove(key)
            return "(deleted)"
        }
        return "(nil)"
    }

    fn keys(self) -> string {
        if self.data.size() == 0 {
            return "(empty)"
        }
        mut allKeys = self.data.keys()
        mut result = [""]
        for k in allKeys {
            push(result, toString(k))
        }
        removeAt(result, 0)
        return strings.join(result, ", ")
    }

    fn size(self) -> int {
        return self.data.size()
    }

    fn getAll(self) -> string {
        mut allKeys = self.data.keys()
        if len(allKeys) == 0 { return "" }
        mut result = [""]
        for k in allKeys {
            push(result, toString(k))
        }
        removeAt(result, 0)
        return strings.join(result, ",")
    }

    fn getData(self, key: string) -> string {
        if self.data.has(key) {
            return toString(self.data.get(key))
        }
        return ""
    }
}

// ==================== NodeState Actor (copied for unit testing) ====================

actor NodeState {
    role: string,
    nodeId: string,
    port: int,
    primaryAddr: string,
    peers: object,
    peerLastSeen: object,
    electionInProgress: bool,
    votesReceived: object
}

impl NodeState {
    fn new(role: string, nodeId: string, port: int, primaryAddr: string) -> NodeState {
        NodeState {
            role: role,
            nodeId: nodeId,
            port: port,
            primaryAddr: primaryAddr,
            peers: set(),
            peerLastSeen: map(),
            electionInProgress: false,
            votesReceived: set()
        }
    }

    fn getRole(self) -> string {
        return self.role
    }

    fn getNodeId(self) -> string {
        return self.nodeId
    }

    fn getPort(self) -> int {
        return self.port
    }

    fn getPrimaryAddr(self) -> string {
        return self.primaryAddr
    }

    fn setPrimaryAddr(self, addr: string) -> string {
        self.primaryAddr = addr
        return "OK"
    }

    fn setRole(self, newRole: string) -> string {
        mut oldRole = self.role
        self.role = newRole
        return oldRole
    }

    fn addPeer(self, peerAddr: string) -> string {
        self.peers.add(peerAddr)
        self.peerLastSeen.set(peerAddr, System.currentTimeMillis())
        return "OK"
    }

    fn removePeer(self, peerAddr: string) -> string {
        if self.peers.has(peerAddr) {
            self.peers.remove(peerAddr)
            if self.peerLastSeen.has(peerAddr) {
                self.peerLastSeen.remove(peerAddr)
            }
        }
        return "OK"
    }

    fn recordHeartbeat(self, peerAddr: string) -> string {
        self.peerLastSeen.set(peerAddr, System.currentTimeMillis())
        if !self.peers.has(peerAddr) {
            self.peers.add(peerAddr)
        }
        return "OK"
    }

    fn getPeers(self) -> string {
        mut peerList = self.peers.values()
        if len(peerList) == 0 { return "" }
        mut result = [""]
        for i in range(0, len(peerList)) {
            push(result, toString(peerList[i]))
        }
        removeAt(result, 0)
        return strings.join(result, ",")
    }

    fn peerCount(self) -> int {
        return self.peers.size()
    }

    fn startElection(self) -> bool {
        if self.electionInProgress {
            return false
        }
        self.electionInProgress = true
        self.votesReceived = set()
        return true
    }

    fn receiveVote(self, fromNodeId: string) -> int {
        self.votesReceived.add(fromNodeId)
        return self.votesReceived.size()
    }

    fn endElection(self) -> string {
        self.electionInProgress = false
        self.votesReceived = set()
        return "OK"
    }

    fn isElecting(self) -> bool {
        return self.electionInProgress
    }

    fn info(self, keyCount: int) -> string {
        mut peerCount = toString(self.peers.size())
        mut kc = toString(keyCount)
        mut p = toString(self.port)
        return "role=${self.role} node=${self.nodeId} port=$p primary=${self.primaryAddr} peers=$peerCount keys=$kc"
    }
}

// ==================== Tests ====================

println("=== SiyoCluster Unit Tests ===")
println("")

// --- Store Tests ---

println("--- Store: set and get")
mut store = spawn Store.new()
mut r1 = store.set("name", "alice")
testing.assertEqual(r1, "OK", "set returns OK")
mut v1 = store.get("name")
testing.assertEqual(v1, "alice", "get returns stored value")
println("  PASS")

println("--- Store: get missing key")
mut v2 = store.get("missing")
testing.assertEqual(v2, "(nil)", "missing key returns (nil)")
println("  PASS")

println("--- Store: overwrite")
store.set("color", "red")
store.set("color", "blue")
mut v3 = store.get("color")
testing.assertEqual(v3, "blue", "overwrite works")
println("  PASS")

println("--- Store: delete")
store.set("temp", "data")
mut r2 = store.del("temp")
testing.assertEqual(r2, "(deleted)", "del returns (deleted)")
mut v4 = store.get("temp")
testing.assertEqual(v4, "(nil)", "deleted key returns (nil)")
println("  PASS")

println("--- Store: delete missing")
mut r3 = store.del("ghost")
testing.assertEqual(r3, "(nil)", "del missing returns (nil)")
println("  PASS")

println("--- Store: keys")
mut fresh = spawn Store.new()
mut k1 = fresh.keys()
testing.assertEqual(k1, "(empty)", "empty store returns (empty)")
fresh.set("x", "1")
fresh.set("y", "2")
mut k2 = fresh.keys()
testing.assert(contains(k2, "x"), "keys includes x")
testing.assert(contains(k2, "y"), "keys includes y")
println("  PASS")

println("--- Store: size")
mut s1 = toString(fresh.size())
testing.assertEqual(s1, "2", "size is 2")
println("  PASS")

println("--- Store: bulk set (100 keys)")
mut bulk = spawn Store.new()
for i in range(0, 100) {
    bulk.set("key$i", "val$i")
}
mut bulkSize = toString(bulk.size())
testing.assertEqual(bulkSize, "100", "100 keys stored")
mut spot = toString(bulk.get("key50"))
testing.assertEqual(spot, "val50", "key50 has correct value")
println("  PASS")

println("--- Store: getAll and getData")
mut sync = spawn Store.new()
sync.set("a", "1")
sync.set("b", "2")
sync.set("c", "3")
mut allKeysStr = toString(sync.getAll())
mut allKeys = split(allKeysStr, ",")
testing.assertEqual(toString(len(allKeys)), "3", "getAll returns 3 keys")
mut dA = sync.getData("a")
testing.assertEqual(dA, "1", "getData returns value")
mut dMissing = sync.getData("missing")
testing.assertEqual(dMissing, "", "getData missing returns empty")
println("  PASS")

println("")

// --- NodeState Tests ---

println("--- NodeState: init")
mut ns = spawn NodeState.new("primary", "localhost:7001", 7001, "localhost:7001")
mut role = ns.getRole()
testing.assertEqual(role, "primary", "initial role is primary")
mut nid = ns.getNodeId()
testing.assertEqual(nid, "localhost:7001", "nodeId correct")
mut pp = ns.getPrimaryAddr()
testing.assertEqual(pp, "localhost:7001", "primary addr correct")
println("  PASS")

println("--- NodeState: peer management")
ns.addPeer("localhost:7002")
ns.addPeer("localhost:7003")
mut pc = toString(ns.peerCount())
testing.assertEqual(pc, "2", "2 peers")
ns.removePeer("localhost:7002")
mut pc2 = toString(ns.peerCount())
testing.assertEqual(pc2, "1", "1 peer after remove")
println("  PASS")

println("--- NodeState: heartbeat recording")
mut ns2 = spawn NodeState.new("replica", "localhost:7002", 7002, "localhost:7001")
ns2.recordHeartbeat("localhost:7001")
mut pc3 = toString(ns2.peerCount())
testing.assertEqual(pc3, "1", "heartbeat adds peer")
println("  PASS")

println("--- NodeState: election")
mut ns3 = spawn NodeState.new("replica", "localhost:7002", 7002, "localhost:7001")
mut canStart = toString(ns3.startElection())
testing.assertEqual(canStart, "true", "first election starts")
mut canStart2 = toString(ns3.startElection())
testing.assertEqual(canStart2, "false", "duplicate election blocked")
mut isElecting = toString(ns3.isElecting())
testing.assertEqual(isElecting, "true", "election in progress")
ns3.receiveVote("localhost:7002")
ns3.receiveVote("localhost:7003")
ns3.endElection()
mut isElecting2 = toString(ns3.isElecting())
testing.assertEqual(isElecting2, "false", "election ended")
println("  PASS")

println("--- NodeState: role change")
mut ns4 = spawn NodeState.new("replica", "localhost:7002", 7002, "localhost:7001")
mut oldRole = ns4.setRole("primary")
testing.assertEqual(oldRole, "replica", "old role returned")
mut newRole = ns4.getRole()
testing.assertEqual(newRole, "primary", "role updated")
println("  PASS")

println("--- NodeState: info")
mut ns5 = spawn NodeState.new("primary", "localhost:7001", 7001, "localhost:7001")
ns5.addPeer("localhost:7002")
mut info = toString(ns5.info(42))
testing.assert(contains(info, "role=primary"), "info has role")
testing.assert(contains(info, "keys=42"), "info has key count")
testing.assert(contains(info, "peers=1"), "info has peer count")
println("  PASS")

println("")
println("All unit tests passed.")
