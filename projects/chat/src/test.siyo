// SiyoChat v3 Test - Auth, Rooms, PM, Presence, History
import java "java.net.Socket"
import java "java.io.BufferedReader"
import java "java.io.InputStreamReader"
import java "java.io.PrintWriter"
import java "java.lang.Thread"

mut passed = 0
mut failed = 0

fn pass(label: string) {
    println("  PASS " + label)
    passed += 1
}

fn fail(label: string, expected: string, actual: string) {
    println("  FAIL " + label + " expected [" + expected + "] got [" + actual + "]")
    failed += 1
}

fn check(label: string, actual: string, expected: string) {
    if contains(actual, expected) { pass(label) }
    else { fail(label, expected, actual) }
}

// Drain: read lines until we find one containing expected, or timeout
fn drain(r: object, expected: string) -> string {
    mut attempts = 0
    while attempts < 5 {
        imut raw = r.readLine()
        if raw == null { return "(null)" }
        imut line = toString(raw)
        if contains(line, expected) { return line }
        attempts += 1
    }
    return "(not found: " + expected + ")"
}

println("=== SiyoChat v3 Test Suite ===")
println("")

// --- Connect 2 clients ---
mut s1 = Socket.new("localhost", 11111)
mut r1 = BufferedReader.new(InputStreamReader.new(s1.getInputStream()))
mut w1 = PrintWriter.new(s1.getOutputStream(), true)
r1.readLine() // welcome

mut s2 = Socket.new("localhost", 11111)
mut r2 = BufferedReader.new(InputStreamReader.new(s2.getInputStream()))
mut w2 = PrintWriter.new(s2.getOutputStream(), true)
r2.readLine() // welcome

// ===== 1. AUTH =====
println("[1] Auth Tests")

w1.println("/join general")
check("join needs auth", r1.readLine(), "ERR login first")

w1.println("/register Alice secret123")
check("register Alice", r1.readLine(), "OK registered")

w2.println("/register Bob hunter2")
check("register Bob", r2.readLine(), "OK registered")

w1.println("/register Alice other")
check("dup register", r1.readLine(), "ERR nick taken")

w1.println("/login Alice wrongpass")
check("bad password", r1.readLine(), "ERR bad password")

w1.println("/login Alice secret123")
check("login Alice", r1.readLine(), "OK logged in")

w2.println("/login Bob hunter2")
check("login Bob", r2.readLine(), "OK logged in")

// ===== 2. ROOMS =====
println("")
println("[2] Room Tests")

w1.println("/join general")
check("Alice joins", drain(r1, "joined #general"), "joined #general")
Thread.sleep(200)

w2.println("/join general")
check("Bob joins", drain(r2, "joined #general"), "joined #general")
Thread.sleep(200)

// Alice should see Bob joined
check("join broadcast", drain(r1, "Bob joined"), "Bob joined")

// Alice sends a message
w1.println("/msg Hello everyone!")
Thread.sleep(200)
check("room msg received", drain(r2, "Hello everyone"), "Hello everyone")

w1.println("/rooms")
check("list rooms", drain(r1, "#general"), "#general")

// ===== 3. PM =====
println("")
println("[3] PM Tests")

w1.println("/pm Bob secret whisper")
Thread.sleep(200)
check("pm sent", drain(r1, "PM sent"), "PM sent to Bob")
check("pm received", drain(r2, "PM from"), "PM from Alice")

w1.println("/pm Ghost hello")
Thread.sleep(200)
check("pm offline", drain(r1, "ERR user not online"), "ERR user not online")

// ===== 4. PRESENCE =====
println("")
println("[4] Presence Tests")

w1.println("/who")
Thread.sleep(100)
check("who online", drain(r1, "Alice"), "Alice")

w1.println("/who general")
Thread.sleep(100)
check("who in room", drain(r1, "Alice"), "Alice")

// ===== 5. HISTORY =====
println("")
println("[5] History Test")

w2.println("/msg History check msg")
Thread.sleep(200)
drain(r1, "History check") // consume broadcast

w1.println("/history")
Thread.sleep(200)
check("history has data", drain(r1, "Hello everyone"), "Hello everyone")

// ===== 6. DISCONNECT =====
println("")
println("[6] Disconnect Tests")

w2.println("/leave")
check("Bob leaves", drain(r2, "left #general"), "left #general")
Thread.sleep(200)
check("leave broadcast", drain(r1, "Bob"), "Bob")

w1.println("/quit")
check("quit c1", drain(r1, "Bye"), "Bye")
w2.println("/quit")
check("quit c2", drain(r2, "Bye"), "Bye")

s1.close()
s2.close()

println("")
println("Results: " + passed + " passed, " + failed + " failed")
if failed == 0 { println("ALL TESTS PASSED") }
