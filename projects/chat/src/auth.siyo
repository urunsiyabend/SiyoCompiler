// SiyoChat Auth module - password hashing with SHA-256
import java "java.security.MessageDigest"
import java "java.util.HexFormat"

fn hashPassword(password: string) -> string {
    mut md = MessageDigest.getInstance("SHA-256")
    mut bytes = md.digest(password.getBytes())
    mut hex = HexFormat.of()
    return hex.formatHex(bytes)
}
