// SiyoDB Concurrent Stress Test
// 3 clients × 10 SET commands = 30 keys, all concurrent
// Verifies true multi-client parallel access via actor model
import java "java.net.Socket"
import java "java.io.BufferedReader"
import java "java.io.InputStreamReader"
import java "java.io.PrintWriter"
import java "java.lang.System"

fn clientWorker(clientId: int, results: channel) {
    mut socket = Socket.new("localhost", 7777)
    mut reader = BufferedReader.new(InputStreamReader.new(socket.getInputStream()))
    mut writer = PrintWriter.new(socket.getOutputStream(), true)
    reader.readLine() // consume welcome

    // SET 10 unique keys
    for i in range(0, 10) {
        imut key = "c" + clientId + "_key" + i
        imut value = "val_" + clientId + "_" + i
        writer.println("SET " + key + " " + value)
        imut resp = reader.readLine()
        if resp != "OK" {
            results.send("FAIL: SET " + key + " got " + resp)
            socket.close()
            return
        }
    }

    // GET all 10 keys back
    mut verified = 0
    for i in range(0, 10) {
        imut key = "c" + clientId + "_key" + i
        imut expected = "val_" + clientId + "_" + i
        writer.println("GET " + key)
        imut resp = reader.readLine()
        if resp == expected {
            verified += 1
        } else {
            results.send("FAIL: GET " + key + " expected " + expected + " got " + resp)
            socket.close()
            return
        }
    }

    writer.println("QUIT")
    reader.readLine()
    socket.close()
    results.send("OK:" + clientId + ":" + verified)
}

// === Main ===
println("=== SiyoDB Concurrent Stress Test ===")
println("3 clients × 10 SET/GET = 30 operations")
println("")

imut results = channel()
imut t0 = System.currentTimeMillis()

// Launch 3 clients concurrently
scope {
    spawn { clientWorker(1, results) }
    spawn { clientWorker(2, results) }
    spawn { clientWorker(3, results) }

    // Collector
    spawn {
        mut passed = 0
        mut failed = 0
        for i in range(0, 3) {
            imut r = toString(results.receive())
            if startsWith(r, "OK") {
                println("  Client " + r + " PASSED")
                passed += 1
            } else {
                println("  " + r)
                failed += 1
            }
        }
        imut elapsed = System.currentTimeMillis() - t0
        println("")
        if passed == 3 {
            println("ALL 3 CLIENTS PASSED (" + elapsed + "ms)")
        } else {
            println("FAILED: " + failed + " clients had errors")
        }
    }
}

// Verify total key count
import java "java.net.Socket"
mut verifySocket = Socket.new("localhost", 7777)
mut vr = BufferedReader.new(InputStreamReader.new(verifySocket.getInputStream()))
mut vw = PrintWriter.new(verifySocket.getOutputStream(), true)
vr.readLine() // welcome
vw.println("KEYS")
imut allKeys = vr.readLine()
imut keyCount = len(split(allKeys, ","))
vw.println("QUIT")
vr.readLine()
verifySocket.close()

println("")
println("Total keys in store: " + keyCount)
if keyCount == 30 {
    println("VERIFIED: All 30 keys present — true concurrent access confirmed")
} else {
    println("ERROR: Expected 30 keys, got " + keyCount)
}
