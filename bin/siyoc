#!/usr/bin/env bash
# Siyo Compiler launcher (delegates to .bat on Windows for classpath handling)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SIYO_JAR="$SCRIPT_DIR/../target/siyo-compiler-0.1.0-SNAPSHOT-shaded.jar"

if [ ! -f "$SIYO_JAR" ]; then
    echo "Error: siyo-compiler JAR not found. Run 'mvn package -DskipTests'"
    exit 1
fi

# Check if we have -cp flag (needs special Windows handling)
HAS_CP=false
for arg in "$@"; do
    [[ "$arg" == "-cp" || "$arg" == "--classpath" ]] && HAS_CP=true
done

if [[ "$HAS_CP" == "true" ]] && [[ "$(uname -s)" == MINGW* || "$(uname -s)" == MSYS* ]]; then
    # On Windows Git Bash, delegate to .bat for correct classpath separator handling
    cmd //c "$(cygpath -w "$SCRIPT_DIR/siyoc.bat")" "$@"
else
    # Unix or no -cp flag
    java -jar "$SIYO_JAR" "$@"
fi
