#!/bin/sh
# Siyo Compiler launcher
# Works in two modes:
#   1. Distribution: bundled runtime/ + lib/siyoc.jar (no Java required)
#   2. Development:  target/ shaded JAR (requires system Java)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SIYO_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"

# Distribution mode: bundled JRE
if [ -f "$SIYO_HOME/lib/siyoc.jar" ] && [ -d "$SIYO_HOME/runtime" ]; then
    exec "$SIYO_HOME/runtime/bin/java" -jar "$SIYO_HOME/lib/siyoc.jar" "$@"
fi

# Development mode: shaded JAR from Maven build
SIYO_JAR="$SIYO_HOME/target/siyo-compiler-0.2.0-shaded.jar"
if [ ! -f "$SIYO_JAR" ]; then
    # Try non-snapshot name (release build)
    SIYO_JAR=$(ls "$SIYO_HOME"/target/siyo-compiler-*.jar 2>/dev/null | grep -v original | head -1)
fi

if [ ! -f "$SIYO_JAR" ]; then
    echo "Error: siyo-compiler JAR not found. Run 'mvn package -DskipTests'"
    exit 1
fi

exec java -jar "$SIYO_JAR" "$@"
